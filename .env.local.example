# GCP Project ID (Cloud Run デプロイ時に使用)
PROJECT_ID=your-gcp-project-id

# PostgreSQL 接続 URL
# ローカル開発: docker compose up -d db の後に使用
DATABASE_URL="postgresql://dayly_report:dayly_report@localhost:5433/dayly_report"

# 本番環境 (Cloud SQL): Cloud Run の環境変数として設定
# DATABASE_URL="postgresql://USER:PASSWORD@/DATABASE?host=/cloudsql/PROJECT:REGION:INSTANCE"
